@model IEnumerable<Endpoint>

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-plug"></i>
            Endpoints
        </h3>
        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                <i class="fas fa-minus"></i>
            </button>
        </div>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Name</th>
                    <th>Display name</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var endpoint in Model)
                {
                <tr>
                    <td>@endpoint.TypeName</td>
                    <td>@endpoint.Name</td>
                    <td>@endpoint.DisplayName</td>
                    <td>@endpoint.Description</td>

                </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- /.card-body -->
</div>
