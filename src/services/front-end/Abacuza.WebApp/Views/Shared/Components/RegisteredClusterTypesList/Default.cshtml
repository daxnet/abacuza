@model IEnumerable<ClusterType>

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-plug"></i>
            Cluster types
        </h3>
        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                <i class="fas fa-minus"></i>
            </button>
        </div>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th style="width: 40px">Type</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var clusterType in Model)
                {
                    <tr>
                        <td>@clusterType.Name</td>
                        <td>@clusterType.Description</td>
                        <td>@clusterType.Type</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- /.card-body -->
</div>
