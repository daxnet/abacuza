{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build_ids",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/auth/Abacuza.Services.Identity",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build_web",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/front-end/Abacuza.WebApp",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}